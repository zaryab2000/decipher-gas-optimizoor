{
  "hooks": [
    {
      "event": "PostToolUse",
      "tool": "Write",
      "filter": { "file_path_pattern": "src/**/*.sol" },
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gas-regression-guard.sh",
      "timeout": 60,
      "on_error": "warn"
    },
    {
      "event": "PostToolUse",
      "tool": "Edit",
      "filter": { "file_path_pattern": "src/**/*.sol" },
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gas-regression-guard.sh",
      "timeout": 60,
      "on_error": "warn"
    }
  ]
}
